PORT=3010
DATA_DIR=./data

# Shared secret expected in X-Portal-Auth when the portal forwards identity.
# Set the same value in the portal and video containers in production.
PORTAL_SHARED_SECRET=

# Public origin used by the share button. If unset, share URLs stay relative.
# PUBLIC_ORIGIN=https://your-domain.example

# Folder used by the admin import endpoint.
# IMPORT_SOURCE_DIR=/Users/woosj/DevelopMac/youtube_create

# Maximum number of concurrent ffmpeg transcode workers.
TRANSCODE_CONCURRENCY=2
